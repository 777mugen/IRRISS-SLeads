# Database
DATABASE_URL=postgresql+asyncpg://localhost/sleads_dev

# API Keys
JINA_API_KEY=your_jina_api_key_here
ZAI_API_KEY=your_zai_api_key_here
ZAI_MODEL=glm-5

# Feishu Notification
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_here
TENDER_KEYWORDS=免疫荧光,mIF,病理,病理诊断,医学检测

# Scheduling
SCHEDULE_HOUR=6
SCHEDULE_MINUTE=0

# Logging
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30
